# ComplyAgent — environment variables template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- LLM (Google Gemini) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Embeddings (Voyage AI) ---
# Get from: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=

# --- Database + vector store (Supabase) ---
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# `service_role` bypasses Row-Level Security. Never expose to a browser or commit.
SUPABASE_SERVICE_ROLE_KEY=

# --- Observability (Langfuse Cloud) ---
# Get from: Langfuse Cloud → project → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- GitHub (Phase 5: auto-create Issues on Hyperswitch fork) ---
# Fine-grained PAT scoped to your hyperswitch fork only.
# Create at: https://github.com/settings/personal-access-tokens/new
# Repository access: only your fork. Permissions: Issues = Read & write.
GITHUB_TOKEN=
